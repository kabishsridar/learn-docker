services:
  db_replica_2:
    environment:
    - POSTGRES_USER=myuser
    - POSTGRES_PASSWORD=mypassword
    - POSTGRES_DB=fastapidb
    image: postgres:15
    ports:
    - 5436:5432
    volumes:
    - pgdata_replica_2:/var/lib/postgresql/data
  web:
    ports:
    - 5004:5000
  web_replica_2:
    build: .
    depends_on:
    - db
    environment:
    - DATABASE_URL=postgresql://myuser:mypassword@db:5432/fastapidb
    image: fastapi-db-cam:latest
    ports:
    - 5005:5000
    restart: always
version: '3.8'
volumes:
  pgdata_replica_2: {}
